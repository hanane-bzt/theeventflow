# =============================================================================
# EventFlow — Backend Symfony
# Copier ce fichier en .env.local et adapter les valeurs
# Ne jamais commiter .env.local
# =============================================================================

# Environnement Symfony (dev | prod | test)
APP_ENV=dev
APP_SECRET=change_me_with_a_random_32_char_string

# Base de données
# SQLite (développement local)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
# MySQL (production recommandée)
# DATABASE_URL="mysql://user:password@127.0.0.1:3306/eventflow?serverVersion=8.0"
# PostgreSQL
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/eventflow?serverVersion=14"

# JWT (LexikJWTBundle)
# Clés générées avec : php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase_here
# Durée de validité du token (en secondes) — 3600 = 1 heure
JWT_TOKEN_TTL=3600

# CORS (origines autorisées pour le frontend)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
